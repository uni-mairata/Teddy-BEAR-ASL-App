<screen>
	<view style_bg_color="0x264653" style_text_color="0xfff">
		<lv_label text="ASL sign you chose: " align="top_left" x="10" y="10" />
		<lv_label bind_text="selected_letter" align="top_left" x="160" y="10" width="53" height="37" />

		<lv_label text="Detected ASL sign:" y="-40" x="10" align="left_mid" style_text_align="center" />

		<!-- This is where the video feed should be -->

		<!-- This button should open the main screen  -->
		<lv_button align="bottom_right" y="-10" x="-10" style_bg_color="0x2a9d8f">
			<lv_label text="Back" />
			<screen_load_event screen="screen_main" anim_type="move_bottom" duration="500" />
		</lv_button>
	</view>
</screen>
